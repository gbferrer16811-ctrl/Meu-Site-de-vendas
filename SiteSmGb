<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StreamX</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #1c1c1c;
    color: white;
}

header {
    text-align: center;
    padding: 20px;
    font-size: 26px;
    font-weight: bold;
}

.container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    padding: 20px;
}

.card {
    background: #2a2a2a;
    margin: 10px;
    padding: 15px;
    width: 230px;
    border-radius: 15px;
    text-align: center;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

/* IMAGEM */
.card img {
    width: 100%;
    border-radius: 10px;
}

/* PREÇO */
.price {
    margin: 10px 0;
    font-size: 20px;
}

/* BOTÕES PERSONALIZADOS */
.netflix button { background: #e50914; }
.prime button { background: #00a8e1; }
.disney button { background: #113ccf; }
.spotify button { background: #1db954; }
.default button { background: gray; }

button {
    width: 100%;
    padding: 10px;
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: bold;
    cursor: pointer;
}

footer {
    text-align: center;
    padding: 20px;
    color: #aaa;
}
</style>
</head>

<body>

<header>StreamX Premium</header>

<div class="container">

<div class="card netflix">
    <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg">
    <h3>Netflix</h3>
    <p class="price">R$6</p>
    <button onclick="comprar('Netflix')">Comprar</button>
</div>

<div class="card prime">
    <img src="https://upload.wikimedia.org/wikipedia/commons/f/f1/Prime_Video.png">
    <h3>Prime Video</h3>
    <p class="price">R$6</p>
    <button onclick="comprar('Prime Video')">Comprar</button>
</div>

<div class="card disney">
    <img src="https://upload.wikimedia.org/wikipedia/commons/3/3e/Disney%2B_logo.svg">
    <h3>Disney+</h3>
    <p class="price">R$6</p>
    <button onclick="comprar('Disney+')">Comprar</button>
</div>

<div class="card spotify">
    <img src="https://upload.wikimedia.org/wikipedia/commons/1/19/Spotify_logo_without_text.svg">
    <h3>Spotify</h3>
    <p class="price">R$7</p>
    <button onclick="comprar('Spotify')">Comprar</button>
</div>

<div class="card default">
    <h3>Outros serviços</h3>
    <p class="price">A partir de R$5</p>
    <button onclick="comprar('Plano')">Comprar</button>
</div>

</div>

<footer>Atendimento via WhatsApp</footer>

<script>
function comprar(produto) {
    let numero = "5518981766576";
    let mensagem = "Quero comprar " + produto;
    let url = "https://wa.me/" + numero + "?text=" + encodeURIComponent(mensagem);
    window.location.href = url;
}
</script>

</body>
</html>
